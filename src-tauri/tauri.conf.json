{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LexTimer",
  "version": "1.0.0",
  "identifier": "com.lextimer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Advocatos",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
